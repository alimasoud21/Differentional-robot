        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://articubot_one/meshes/base_link.STL"/>
            </geometry>
            <material name="silver"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://articubot_one/meshes/base_link.STL"/>
            </geometry>
        </collision>
    </link>

    <link name="wheel_right_Link">
